       fhir:ElementDefinition.constraint [
         fhir:index 0 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "bdl-1" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "total only when a search or history" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "total.empty() or (type = 'searchset') or (type = 'history')" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "not(f:total) or (f:type/@value = 'searchset') or (f:type/@value = 'history')" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Bundle" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Bundle>
         ]
       ], [
         fhir:index 1 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "bdl-2" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "entry.search only when a search" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "entry.search.empty() or (type = 'searchset')" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "not(f:entry/f:search) or (f:type/@value = 'searchset')" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Bundle" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Bundle>
         ]
       ], [
         fhir:index 2 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "bdl-3" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "entry.request mandatory for batch/transaction/history, otherwise prohibited" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "entry.all(request.exists() = (%resource.type = 'batch' or %resource.type = 'transaction' or %resource.type = 'history'))" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "not(f:entry/f:request) or (f:type/@value = 'batch') or (f:type/@value = 'transaction') or (f:type/@value = 'history')" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Bundle" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Bundle>
         ]
       ], [
         fhir:index 3 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "bdl-4" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "entry.response mandatory for batch-response/transaction-response/history, otherwise prohibited" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "entry.all(response.exists() = (%resource.type = 'batch-response' or %resource.type = 'transaction-response' or %resource.type = 'history'))" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "not(f:entry/f:response) or (f:type/@value = 'batch-response') or (f:type/@value = 'transaction-response') or (f:type/@value = 'history')" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Bundle" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Bundle>
         ]
       ], [
         fhir:index 4 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "bdl-7" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "FullUrl must be unique in a bundle, or else entries with the same fullUrl must have different meta.versionId (except in history bundles)" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "(type = 'history') or entry.where(fullUrl.exists()).select(fullUrl&resource.meta.versionId).isDistinct()" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "(f:type/@value = 'history') or (count(for $entry in f:entry[f:resource] return $entry[count(parent::f:Bundle/f:entry[f:fullUrl/@value=$entry/f:fullUrl/@value and ((not(f:resource/*/f:meta/f:versionId/@value) and not($entry/f:resource/*/f:meta/f:versionId/@value)) or f:resource/*/f:meta/f:versionId/@value=$entry/f:resource/*/f:meta/f:versionId/@value)])!=1])=0)" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Bundle" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Bundle>
         ]
       ], [
         fhir:index 5 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "bdl-9" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "A document must have an identifier with a system and a value" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "type = 'document' implies (identifier.system.exists() and identifier.value.exists())" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "not(f:type/@value = 'document') or exists(f:identifier/f:system) or exists(f:identifier/f:value)" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Bundle" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Bundle>
         ]
       ], [
         fhir:index 6 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "bdl-10" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "A document must have a date" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "type = 'document' implies (timestamp.hasValue())" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "not(f:type/@value = 'document') or exists(f:timestamp/@value)" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Bundle" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Bundle>
         ]
       ], [
         fhir:index 7 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "bdl-11" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "A document must have a Composition as the first resource" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "type = 'document' implies entry.first().resource.is(Composition)" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "not(f:type/@value='document') or f:entry[1]/f:resource/f:Composition" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Bundle" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Bundle>
         ]
       ], [
         fhir:index 8 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "bdl-12" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "A message must have a MessageHeader as the first resource" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "type = 'message' implies entry.first().resource.is(MessageHeader)" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "not(f:type/@value='message') or f:entry[1]/f:resource/f:MessageHeader" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/StructureDefinition/Bundle" ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Bundle>
         ]
