         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "At least one consent in the Advanced Directives section must be SmartConsent" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "Bundle.entry.resource.ofType(Composition).section.where(title='Advance Directives').entry.resolve().where(conformsTo('http://smart.who.int/ph4h/StructureDefinition/SmartConsent')).exists()" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://smart.who.int/ph4h/StructureDefinition/SmartIPS" ;
           fhir:link <http://smart.who.int/ph4h/StructureDefinition/SmartIPS>
         ]
