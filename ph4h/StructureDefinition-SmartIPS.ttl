         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "An IPS document must have no additional Composition (including Composition subclass) resources besides the first." ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "entry.tail().where(resource is Composition).empty()" ] ;
         fhir:ElementDefinition.constraint.source [
           fhir:value "http://hl7.org/fhir/uv/ips/StructureDefinition/Bundle-uv-ips" ;
           fhir:link <http://hl7.org/fhir/uv/ips/StructureDefinition/Bundle-uv-ips>
         ]
       ], [
         fhir:index 10 ;
         fhir:ElementDefinition.constraint.key [ fhir:value "containsSmartConsent" ] ;
         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "At least one entry in the Bundle must be SmartConsent" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "Bundle.entry.resource.ofType(Consent).where(conformsTo('http://smart.who.int/ph4h/StructureDefinition/SmartConsent')).exists()" ] ;
